# Global shared defaults
OPENAI_API_BASE=http://127.0.0.1:4000/v1 # OpenAI-compatible base URL (LiteLLM)
OPENAI_API_KEY= # Optional bearer key for OpenAI-compatible endpoints
DEFAULT_MODEL=openai/gpt-5.4 # Unified default model across services
DB_HOST=127.0.0.1 # Host-mode DB endpoint
DB_PORT=5432 # Default postgres port
